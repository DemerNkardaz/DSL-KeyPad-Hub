{
  "name": "DSL KeyPad",
  "type": "dark",
  "colors": {
    "editor.background": "#333333",
    "editor.foreground": "#F8F8F2",
    "editorCursor.foreground": "#F8F8F0",
    "editor.selectionBackground": "#444444",
    "editor.lineHighlightBackground": "#3E3D32",
    "editorWhitespace.foreground": "#3B3A32"
  },
  "tokenColors": [
    {
      "scope": "comment",
      "settings": {
        "foreground": "#85837B"
      }
    },
    {
      "scope": "string",
      "settings": {
        "foreground": "#E6DB74"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#FFC400"
      }
    },
    {
      "scope": "constant.language",
      "settings": {
        "foreground": "#F53F7F",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "constant.character, constant.other",
      "settings": {
        "foreground": "#D67FFF"
      }
    },
    {
      "scope": "variable",
      "settings": {
        "foreground": "#EEEEEE"
      }
    },
    {
      "scope": "keyword",
      "settings": {
        "foreground": "#E1D833"
      }
    },
    {
      "scope": "storage",
      "settings": {
        "foreground": "#AAF54F"
      }
    },
    {
      "scope": "storage.type",
      "settings": {
        "foreground": "#AEFF4C",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "entity.name.class",
      "settings": {
        "foreground": "#27FF9F",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "entity.other.inherited-class",
      "settings": {
        "foreground": "#27FF9F",
        "fontStyle": "italic bold"
      }
    },
    {
      "scope": "entity.name.function",
      "settings": {
        "foreground": "#7AF5A3"
      }
    },
    {
      "scope": "variable.parameter",
      "settings": {
        "foreground": "#8FC9FF",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "entity.name.tag",
      "settings": {
        "foreground": "#85D6FF"
      }
    },
    {
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#C5FF52"
      }
    },
    {
      "scope": "support.function",
      "settings": {
        "foreground": "#31E673"
      }
    },
    {
      "scope": "support.constant",
      "settings": {
        "foreground": "#DDDDDD"
      }
    },
    {
      "scope": "support.type, support.class",
      "settings": {
        "foreground": "#F7E34F",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "support.other.variable",
      "settings": {
        "foreground": "#EEEEEE"
      }
    },
    {
      "scope": "invalid",
      "settings": {
        "foreground": "#F8F8F0",
        "background": "#EB2F2F"
      }
    },
    {
      "scope": "invalid.deprecated",
      "settings": {
        "foreground": "#F8F8F0",
        "background": "#FF907F"
      }
    },
    {
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#fa8e6e"
      }
    },
    {
      "scope": "keyword.operator.new",
      "settings": {
        "foreground": "#8FC9FF"
      }
    },
    {
      "scope": "variable.language",
      "settings": {
        "foreground": "#F53F7F"
      }
    }
  ]
}